# ==================== CONFIGURATION GÉNÉRALE ====================

# Environnement (development, production, testing)
FLASK_ENV=development

# Clé secrète (GÉNÉREZ UNE CLÉ ALÉATOIRE EN PRODUCTION)
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire-changez-moi-en-production

# ==================== BASE DE DONNÉES ====================

# SQLite (par défaut - recommandé pour développement)
DATABASE_URL=sqlite:///ia_system.db

# PostgreSQL (recommandé pour production)
# DATABASE_URL=postgresql://username:password@localhost:5432/ia_system

# MySQL
# DATABASE_URL=mysql://username:password@localhost:3306/ia_system

# ==================== SÉCURITÉ ====================

# Session (en production, activer HTTPS)
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Rate limiting
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_DEFAULT=100 per hour

# ==================== EMAIL (OPTIONNEL) ====================

# Configuration SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-application

# ==================== IA CONFIGURATION ====================

# Paramètres du moteur IA
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
ENABLE_HUMAN_VALIDATION=True

# API externe (si utilisée)
# ANTHROPIC_API_KEY=your-api-key-here
# OPENAI_API_KEY=your-api-key-here

# ==================== RGPD ====================

# Rétention des données (en jours)
DATA_RETENTION_DAYS=365

# Consentement obligatoire
CONSENT_REQUIRED=True

# ==================== LOGGING ====================

# Niveau de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Fichier de log
LOG_FILE=logs/system.log

# ==================== PERFORMANCE ====================

# Cache
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# ==================== DÉVELOPPEMENT ====================

# Debug (JAMAIS en production)
DEBUG=True

# Recharger automatiquement
FLASK_DEBUG=1

# ==================== PRODUCTION ====================

# En production, définir ces variables :
# - Générer une SECRET_KEY forte : python -c "import secrets; print(secrets.token_hex(32))"
# - Utiliser PostgreSQL au lieu de SQLite
# - Activer HTTPS (SESSION_COOKIE_SECURE=True)
# - Désactiver DEBUG (DEBUG=False)
# - Configurer un serveur SMTP réel
# - Sauvegarder régulièrement la base de données